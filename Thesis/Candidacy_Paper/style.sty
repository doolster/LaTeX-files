\newcommand\TRI[3]{
\begin{tikzpicture}[scale=.5]
	\coordinate (1) at (90:1cm);
	\coordinate (2) at (210:1cm);
	\coordinate (3) at (-30:1cm);
	\draw (1) to (2) to (3) to (1);
	\node[] at (90:1.3cm) {\scriptsize$#1$};
	\node[] at (210:1.3cm) {\scriptsize$#2$};
	\node[] at (-30:1.3cm) {\scriptsize$#3$};
\end{tikzpicture}}

